# Narevo environment (copy to .env; never commit .env)

# --- Postgres (canonical store) ---
DATABASE_URL=postgresql://narevo:narevo@localhost:5432/narevo

# --- MinIO (WORM raw archive) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=narevo-archive

# --- Neo4j (graph projection) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- PeaDF extraction service ---
PEADF_EXTRACT_URL=
PEADF_API_TOKEN=

# --- LLM / vision (optional, cost-gated fallback) ---
LLM_API_KEY=
LLM_MODEL=

# --- Web ---
VITE_API_BASE_URL=http://localhost:8000
