# NaijaLedger environment (copy to .env; never commit .env)

# --- Postgres (canonical store) ---
DATABASE_URL=postgresql+psycopg://naijaledger:naijaledger@localhost:5432/naijaledger

# --- MinIO (WORM raw archive) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=naijaledger-archive

# --- Memgraph (graph projection) ---
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# --- Extraction ---
# Magika content-type confidence floor; below this → quarantine (no parse).
MAGIKA_MIN_CONFIDENCE=0.5

# --- PeaDF extraction service (hosted, optional) ---
PEADF_BASE_URL=
PEADF_API_KEY=

# --- LLM / vision (optional, cost-gated fallback) ---
LLM_API_KEY=
LLM_MODEL=

# --- Web ---
# Dev default `/api` is proxied by Vite to the engine (see web/vite.config.ts).
# Set to full URL (e.g. http://localhost:8000) only if not using the Vite dev server.
VITE_API_BASE_URL=/api
